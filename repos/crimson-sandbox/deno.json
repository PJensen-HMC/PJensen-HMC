{
  "name": "@crimsonsdk/sdk",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./testing": "./src/testing.ts",
    "./runtime": "./src/runtime.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "dev": "deno run --watch src/mod.ts",
    "test": "deno test --allow-all tests/",
    "test:watch": "deno test --watch --allow-all tests/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/mod.ts"
  },
  "lint": {
    "include": ["src/", "tests/"]
  },
  "fmt": {
    "include": ["src/", "tests/"]
  },
  "compilerOptions": {
    "strict": true
  }
}
