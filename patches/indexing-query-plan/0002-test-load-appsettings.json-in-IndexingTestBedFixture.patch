From 4edb4603996fea3b0409e5dcd89876765c401e71 Mon Sep 17 00:00:00 2001
From: "Jensen, Pete" <jensenp@hmc.harvard.edu>
Date: Mon, 20 Apr 2026 19:49:03 +0000
Subject: [PATCH 2/7] test: load appsettings.json in IndexingTestBedFixture for
 local connection strings

Fixture previously only loaded appsettings.Cloud.json, leaving no path
for local AzureAppConfiguration connection strings. Add appsettings.json
as an optional source (not committed with secrets) so the credential
chain resolves without DefaultAzureCredential on dev machines.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 .../Fixtures/IndexingTestBedFixture.cs                   | 9 ++-------
 .../HMC.Shared.ResearchManagementIndex.Tests.csproj      | 9 ++++++---
 .../appsettings.json                                     | 3 +++
 3 files changed, 11 insertions(+), 10 deletions(-)
 create mode 100644 Tests/HMC.Shared.ResearchManagementIndex.Tests/appsettings.json

diff --git a/Tests/HMC.Shared.ResearchManagementIndex.Tests/Fixtures/IndexingTestBedFixture.cs b/Tests/HMC.Shared.ResearchManagementIndex.Tests/Fixtures/IndexingTestBedFixture.cs
index 6e572c3..ee5665a 100644
--- a/Tests/HMC.Shared.ResearchManagementIndex.Tests/Fixtures/IndexingTestBedFixture.cs
+++ b/Tests/HMC.Shared.ResearchManagementIndex.Tests/Fixtures/IndexingTestBedFixture.cs
@@ -33,13 +33,8 @@ public class IndexingTestBedFixture : TestBedFixture
 
     protected override IEnumerable<TestAppSettings> GetTestAppSettings()
     {
-        const string settingFileName = "appsettings.Cloud.json";
-
-        yield return new TestAppSettings
-        {
-            Filename = settingFileName,
-            IsOptional = false,
-        };
+        yield return new TestAppSettings { Filename = "appsettings.json",       IsOptional = true  };
+        yield return new TestAppSettings { Filename = "appsettings.Cloud.json", IsOptional = false };
     }
 
     /// <summary>
diff --git a/Tests/HMC.Shared.ResearchManagementIndex.Tests/HMC.Shared.ResearchManagementIndex.Tests.csproj b/Tests/HMC.Shared.ResearchManagementIndex.Tests/HMC.Shared.ResearchManagementIndex.Tests.csproj
index ab37bb5..3e7e6b5 100644
--- a/Tests/HMC.Shared.ResearchManagementIndex.Tests/HMC.Shared.ResearchManagementIndex.Tests.csproj
+++ b/Tests/HMC.Shared.ResearchManagementIndex.Tests/HMC.Shared.ResearchManagementIndex.Tests.csproj
@@ -10,9 +10,9 @@
   </PropertyGroup>
 
   <ItemGroup>
-    <PackageReference Include="coverlet.collector" Version="8.0.1">
-      <PrivateAssets>all</PrivateAssets>
-      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
+    <PackageReference Include="coverlet.collector" Version="8.0.1">
+      <PrivateAssets>all</PrivateAssets>
+      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
     </PackageReference>
     <PackageReference Include="HMC.Shared.Configuration" Version="3.0.0.7" />
     <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
@@ -33,6 +33,9 @@
   </ItemGroup>
 
   <ItemGroup>
+    <None Update="appsettings.json">
+      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
+    </None>
     <None Update="appsettings.Cloud.json">
       <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
     </None>
diff --git a/Tests/HMC.Shared.ResearchManagementIndex.Tests/appsettings.json b/Tests/HMC.Shared.ResearchManagementIndex.Tests/appsettings.json
new file mode 100644
index 0000000..bdb02b8
--- /dev/null
+++ b/Tests/HMC.Shared.ResearchManagementIndex.Tests/appsettings.json
@@ -0,0 +1,3 @@
+{
+  "AzureAppConfiguration": ""
+}
-- 
2.34.1

