+using HMC.Shared.ResearchManagementIndex.Tests.Fixtures;
+using Xunit.Abstractions;
+using Xunit.Microsoft.DependencyInjection.Abstracts;
+
+namespace HMC.Shared.ResearchManagementIndex.Tests.Service;
+
+public class IndexQueryPlannerTests : TestBed<IndexingTestBedFixture>
+{
+    private readonly IndexingService? _indexingService;
+
+    public IndexQueryPlannerTests(ITestOutputHelper testOutputHelper, IndexingTestBedFixture fixture)
+        : base(testOutputHelper, fixture)
+    {
+        _indexingService = _fixture.GetService<IndexingService>(_testOutputHelper);
+    }
+
+    [Fact]
+    public async Task BuildQueryPlan_ProducesEvenDistribution()
+    {
+        var outputPath = Path.Combine(Path.GetTempPath(), "index-query-plan.txt");
+
+        var planner = new IndexQueryPlanner(
+            _indexingService!.PrimarySearchClient,
+            new IndexQueryPlannerOptions { OutputPath = outputPath });
+
+        var plan = await planner.BuildPlanAsync();
+
+        _testOutputHelper.WriteLine($"Fetches : {plan.FetchCount}");
+        _testOutputHelper.WriteLine($"Chunks  : {plan.TotalChunks:N0}");
+        _testOutputHelper.WriteLine($"Plan    : {outputPath}");
+        _testOutputHelper.WriteLine(string.Empty);
+
+        foreach (var entry in plan.Entries)
+            _testOutputHelper.WriteLine($"  {entry.Filter,-50}  {entry.Count,10:N0}");
+
+        Assert.NotEmpty(plan.Entries);
+        Assert.True(plan.TotalChunks > 0);
+    }
+}
