+namespace HMC.Shared.ResearchManagementIndex;
+
+public sealed class IndexQueryPlannerOptions
+{
+    /// <summary>Cut a new bucket when estimated chunks reach this threshold.</summary>
+    public int Target { get; init; } = 80_000;
+
+    /// <summary>Write the finished plan to this path. Null = skip file output.</summary>
+    public string? OutputPath { get; init; }
+}
