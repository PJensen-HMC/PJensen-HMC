+using Azure.Search.Documents;
+using Azure.Search.Documents.Models;
+
+namespace HMC.Shared.ResearchManagementIndex;
+
+/// <summary>
+/// Builds an adaptive lexical-prefix query plan that tiles a search index into
+/// fetch buckets each containing at most <see cref="IndexQueryPlannerOptions.Target"/> chunks.
+///
+/// Algorithm: recursively subdivide Id-prefix buckets via count-only queries ($top=0)
+/// until every leaf is within the target. No document enumeration required.
+/// </summary>
+public sealed class IndexQueryPlanner(SearchClient searchClient, IndexQueryPlannerOptions options)
+{
+    private static readonly char[] HexChars = "0123456789abcdef".ToCharArray();
+
+    public async Task<IndexQueryPlan> BuildPlanAsync(CancellationToken ct = default)
+    {
+        var entries = new List<QueryPlanEntry>();
+
+        for (var i = 0; i < 16; i++)
+        {
+            var prefix = HexChars[i].ToString();
+            var upper  = i < 15 ? HexChars[i + 1].ToString() : null;
+            await SubdivideAsync(prefix, upper, entries, ct);
+        }
+
+        var plan = new IndexQueryPlan(entries);
+
+        if (options.OutputPath != null)
+            await WritePlanAsync(plan, ct);
+
+        return plan;
+    }
+
+    private async Task SubdivideAsync(
+        string prefix, string? upper,
+        List<QueryPlanEntry> results,
+        CancellationToken ct)
+    {
+        var filter = BuildFilter(prefix, upper);
+        var count  = await CountAsync(filter, ct);
+
+        if (count <= options.Target)
+        {
+            results.Add(new QueryPlanEntry(filter, count));
+            return;
+        }
+
+        // Subdivide into 16 hex children.
+        for (var i = 0; i < 16; i++)
+        {
+            var childPrefix = prefix + HexChars[i];
+            var childUpper  = i < 15 ? prefix + HexChars[i + 1] : upper;
+            await SubdivideAsync(childPrefix, childUpper, results, ct);
+        }
+    }
+
+    private async Task<long> CountAsync(string filter, CancellationToken ct)
+    {
+        var searchOptions = new SearchOptions
+        {
+            Filter           = filter,
+            Size             = 0,
+            IncludeTotalCount = true,
+        };
+
+        var response = await searchClient.SearchAsync<SearchDocument>("*", searchOptions, ct);
+        return response.Value.TotalCount ?? 0;
+    }
+
+    private async Task WritePlanAsync(IndexQueryPlan plan, CancellationToken ct)
+    {
+        await using var writer = new StreamWriter(options.OutputPath!, append: false);
+
+        foreach (var entry in plan.Entries)
+            await writer.WriteLineAsync($"{entry.Filter,-50}  {entry.Count,10:N0}");
+
+        await writer.WriteLineAsync();
+        await writer.WriteLineAsync($"Total: {plan.TotalChunks:N0} chunks | {plan.FetchCount} fetches");
+    }
+
+    private static string BuildFilter(string prefix, string? upper) =>
+        upper == null
+            ? $"Id ge '{prefix}'"
+            : $"Id ge '{prefix}' and Id lt '{upper}'";
+
+    // Visible for testing.
+    internal static string? NextHexPrefix(string prefix)
+    {
+        var chars = prefix.ToCharArray();
+        for (var i = chars.Length - 1; i >= 0; i--)
+        {
+            if (chars[i] != 'f')
+            {
+                chars[i] = HexChars[Array.IndexOf(HexChars, chars[i]) + 1];
+                return new string(chars);
+            }
+            chars[i] = '0';
+            if (i == 0) return null;
+        }
+        return null;
+    }
+}
