+namespace HMC.Shared.ResearchManagementIndex;
+
+public sealed class IndexQueryPlan
+{
+    public IReadOnlyList<QueryPlanEntry> Entries { get; }
+    public long TotalChunks { get; }
+    public int FetchCount => Entries.Count;
+
+    internal IndexQueryPlan(IReadOnlyList<QueryPlanEntry> entries)
+    {
+        Entries = entries;
+        TotalChunks = entries.Sum(e => e.Count);
+    }
+}
+
+public sealed record QueryPlanEntry(string Filter, long Count);
