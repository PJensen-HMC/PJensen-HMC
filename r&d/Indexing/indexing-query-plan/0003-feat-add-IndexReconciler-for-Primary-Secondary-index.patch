+using HMC.Shared.ResearchManagementIndex.Tests.Fixtures;
+using Xunit.Abstractions;
+using Xunit.Microsoft.DependencyInjection.Abstracts;
+
+namespace HMC.Shared.ResearchManagementIndex.Tests.Service;
+
+public class IndexReconcilerTests : TestBed<IndexingTestBedFixture>
+{
+    private readonly IndexingService? _indexingService;
+
+    public IndexReconcilerTests(ITestOutputHelper testOutputHelper, IndexingTestBedFixture fixture)
+        : base(testOutputHelper, fixture)
+    {
+        _indexingService = _fixture.GetService<IndexingService>(_testOutputHelper);
+    }
+
+    [Fact]
+    public async Task Reconcile_PrimaryVsSecondary_ReturnsResult()
+    {
+        var planner = new IndexQueryPlanner(
+            _indexingService!.PrimarySearchClient,
+            new IndexQueryPlannerOptions());
+
+        var plan = await planner.BuildPlanAsync();
+
+        var outputPath = Path.Combine(Path.GetTempPath(), "index-reconciliation.txt");
+
+        var reconciler = new IndexReconciler(
+            _indexingService!.PrimarySearchClient,
+            _indexingService!.SecondarySearchClient,
+            new IndexReconcilerOptions { OutputPath = outputPath });
+
+        var result = await reconciler.ReconcileAsync(plan);
+
+        _testOutputHelper.WriteLine($"Buckets            : {result.BucketsProcessed:N0}");
+        _testOutputHelper.WriteLine($"Primary chunks     : {result.PrimaryChunks:N0}");
+        _testOutputHelper.WriteLine($"Primary unique Ids : {result.PrimaryIdCount:N0}");
+        _testOutputHelper.WriteLine($"Secondary Ids      : {result.SecondaryIdCount:N0}");
+        _testOutputHelper.WriteLine($"Missing secondary  : {result.MissingFromSecondary.Count:N0}");
+        _testOutputHelper.WriteLine($"Extra in secondary : {result.ExtraInSecondary.Count:N0}");
+        _testOutputHelper.WriteLine($"Report             : {outputPath}");
+
+        Assert.True(result.PrimaryIdCount > 0);
+        Assert.Equal(plan.FetchCount, result.BucketsProcessed);
+    }
+}
