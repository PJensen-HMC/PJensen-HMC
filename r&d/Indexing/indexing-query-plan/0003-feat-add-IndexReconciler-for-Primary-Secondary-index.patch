+using Azure.Search.Documents;
+using Azure.Search.Documents.Models;
+using System.Collections.Concurrent;
+
+namespace HMC.Shared.ResearchManagementIndex;
+
+/// <summary>
+/// Reconciles Primary (east) and Secondary (west) search indexes at the document-Id grain
+/// by executing a pre-built <see cref="IndexQueryPlan"/> against both clients concurrently.
+///
+/// Each plan bucket is fetched from both clients in parallel; the resulting Id sets are
+/// diffed after all buckets complete.  No document content is retrieved â€” only the Id field.
+/// </summary>
+public sealed class IndexReconciler(
+    SearchClient primaryClient,
+    SearchClient secondaryClient,
+    IndexReconcilerOptions options)
+{
+    public async Task<IndexReconciliationResult> ReconcileAsync(
+        IndexQueryPlan plan,
+        CancellationToken ct = default)
+    {
+        // Buckets are disjoint lexical ranges â€” no Id can appear in two buckets,
+        // so ConcurrentBag accumulation is duplicate-free.
+        var primaryIdBag   = new ConcurrentBag<string>();
+        var secondaryIdBag = new ConcurrentBag<string>();
+
+        await Parallel.ForEachAsync(
+            plan.Entries,
+            new ParallelOptions { MaxDegreeOfParallelism = options.MaxDegreeOfParallelism, CancellationToken = ct },
+            async (entry, innerCt) =>
+            {
+                var primaryTask   = FetchIdsAsync(primaryClient,   entry.Filter, innerCt);
+                var secondaryTask = FetchIdsAsync(secondaryClient, entry.Filter, innerCt);
+                await Task.WhenAll(primaryTask, secondaryTask);
+
+                foreach (var id in primaryTask.Result)
+                    primaryIdBag.Add(id);
+
+                foreach (var id in secondaryTask.Result)
+                    secondaryIdBag.Add(id);
+            });
+
+        var primarySet   = new HashSet<string>(primaryIdBag,   StringComparer.OrdinalIgnoreCase);
+        var secondarySet = new HashSet<string>(secondaryIdBag, StringComparer.OrdinalIgnoreCase);
+
+        var missing = primarySet
+            .Where(id => !secondarySet.Contains(id))
+            .ToHashSet(StringComparer.OrdinalIgnoreCase);
+
+        var extra = secondarySet
+            .Where(id => !primarySet.Contains(id))
+            .ToHashSet(StringComparer.OrdinalIgnoreCase);
+
+        var result = new IndexReconciliationResult(
+            missing,
+            extra,
+            primarySet.Count,
+            secondarySet.Count,
+            plan.TotalChunks,
+            plan.FetchCount);
+
+        if (options.OutputPath != null)
+            await WriteReportAsync(result);
+
+        return result;
+    }
+
+    private static async Task<HashSet<string>> FetchIdsAsync(
+        SearchClient client, string filter, CancellationToken ct)
+    {
+        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
+
+        var searchOptions = new SearchOptions
+        {
+            Filter            = filter,
+            IncludeTotalCount = false
+        };
+        searchOptions.Select.Add("Id");
+
+        var response = await client.SearchAsync<SearchDocument>("*", searchOptions, ct);
+        await foreach (var page in response.Value
+            .GetResultsAsync()
+            .AsPages(pageSizeHint: 1000)
+            .WithCancellation(ct))
+        {
+            foreach (var result in page.Values)
+            {
+                if (result.Document?.TryGetValue("Id", out var val) == true && val != null)
+                    ids.Add(val.ToString()!);
+            }
+        }
+
+        return ids;
+    }
+
+    private async Task WriteReportAsync(IndexReconciliationResult result)
+    {
+        await using var writer = new StreamWriter(options.OutputPath!, append: false);
+
+        await writer.WriteLineAsync("Index Reconciliation Report");
+        await writer.WriteLineAsync($"Generated              : {DateTime.UtcNow:O}");
+        await writer.WriteLineAsync($"Buckets processed      : {result.BucketsProcessed:N0}");
+        await writer.WriteLineAsync($"Primary chunks (plan)  : {result.PrimaryChunks:N0}");
+        await writer.WriteLineAsync($"Primary unique Ids     : {result.PrimaryIdCount:N0}");
+        await writer.WriteLineAsync($"Secondary unique Ids   : {result.SecondaryIdCount:N0}");
+        await writer.WriteLineAsync($"Missing from Secondary : {result.MissingFromSecondary.Count:N0}");
+        await writer.WriteLineAsync($"Extra in Secondary     : {result.ExtraInSecondary.Count:N0}");
+        await writer.WriteLineAsync();
+
+        if (result.MissingFromSecondary.Count > 0)
+        {
+            await writer.WriteLineAsync($"--- Missing from Secondary ({result.MissingFromSecondary.Count}) ---");
+            foreach (var id in result.MissingFromSecondary.OrderBy(static x => x))
+                await writer.WriteLineAsync($"  {id}");
+            await writer.WriteLineAsync();
+        }
+
+        if (result.ExtraInSecondary.Count > 0)
+        {
+            await writer.WriteLineAsync($"--- Extra in Secondary ({result.ExtraInSecondary.Count}) ---");
+            foreach (var id in result.ExtraInSecondary.OrderBy(static x => x))
+                await writer.WriteLineAsync($"  {id}");
+        }
+    }
+}
