+namespace HMC.Shared.ResearchManagementIndex;
+
+public sealed class IndexReconciliationResult
+{
+    /// <summary>Ids present in Primary but absent from Secondary.</summary>
+    public IReadOnlySet<string> MissingFromSecondary { get; }
+
+    /// <summary>Ids present in Secondary but absent from Primary.</summary>
+    public IReadOnlySet<string> ExtraInSecondary { get; }
+
+    /// <summary>Unique document Ids found in Primary.</summary>
+    public int PrimaryIdCount { get; }
+
+    /// <summary>Unique document Ids found in Secondary.</summary>
+    public int SecondaryIdCount { get; }
+
+    /// <summary>Total chunk count from the query plan (count-only queries, not fetched).</summary>
+    public long PrimaryChunks { get; }
+
+    /// <summary>Number of query plan buckets processed.</summary>
+    public int BucketsProcessed { get; }
+
+    internal IndexReconciliationResult(
+        HashSet<string> missingFromSecondary,
+        HashSet<string> extraInSecondary,
+        int primaryIdCount,
+        int secondaryIdCount,
+        long primaryChunks,
+        int bucketsProcessed)
+    {
+        MissingFromSecondary = missingFromSecondary;
+        ExtraInSecondary     = extraInSecondary;
+        PrimaryIdCount       = primaryIdCount;
+        SecondaryIdCount     = secondaryIdCount;
+        PrimaryChunks        = primaryChunks;
+        BucketsProcessed     = bucketsProcessed;
+    }
+}
