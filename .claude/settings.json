{
  "statusLine": {
    "type": "command",
    "command": "/home/devadmin/.claude/statusline.py"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "local@hmc-tools": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "touch /home/devadmin/.claude/.thinking"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_name // empty' | tr -cd '[:alnum:]' | head -c 32 > /home/devadmin/.claude/.current-tool"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // empty'); if echo \"$cmd\" | grep -qE 'git push' && ! echo \"$cmd\" | grep -q 'SAFE_PUSH=1'; then echo 'BLOCKED: Direct git push is disabled. Use /safe-push skill for all pushes.' >&2; exit 1; fi; echo \"$cmd\" | head -c 60 | tr -cd '[:print:]' > /home/devadmin/.claude/.current-tool-ctx"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I{} basename {} | head -c 60 > /home/devadmin/.claude/.current-tool-ctx"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I{} basename {} | head -c 60 > /home/devadmin/.claude/.current-tool-ctx"
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '(.tool_input.pattern // .tool_input.glob // empty)' | head -c 40 | tr -cd '[:print:]' > /home/devadmin/.claude/.current-tool-ctx"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "root=$(git rev-parse --show-toplevel 2>/dev/null); [ -n \"$root\" ] && echo \"$root\" > /home/devadmin/.claude/.last-git-dir || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /home/devadmin/.claude/.thinking /home/devadmin/.claude/.current-tool /home/devadmin/.claude/.current-tool-ctx"
          }
        ]
      }
    ]
  }
}
