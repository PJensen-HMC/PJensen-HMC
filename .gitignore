.DS_Store
Thumbs.db
*~
*.swp
*.swo

.vscode/
.idea/


# ------------------------------------------------------------
# Logs / temp / cache
# ------------------------------------------------------------

*.log
*.tmp
*.bak
*.orig
*.rej

.cache/
tmp/
temp/


# ------------------------------------------------------------
# SSH / terminal-agent local state
# ------------------------------------------------------------

.ssh/
.gnupg/
.local/
.config/
.history
.bash_history
.zsh_history
.lesshst
.python_history

# Keep shell config trackable if present.
!.bashrc
!.profile
!.bash_profile
!.zshrc


# ------------------------------------------------------------
# Secrets / credentials
# ------------------------------------------------------------

.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.p12
*.pfx

.secrets
.secrets.*
!.secrets.example

.claude/.secrets
.claude/.secrets.*
!.claude/.secrets.example


# ------------------------------------------------------------
# Claude / agent local state
# ------------------------------------------------------------

.claude/settings.local.json

# Local/private Claude project memory.
.claude/projects/**/memory/*
!.claude/projects/**/memory/README.md
!.claude/projects/**/memory/*.example.md


# ------------------------------------------------------------
# Repos directory
# ------------------------------------------------------------
# Track the repo registry and bootstrap script.
# Ignore all cloned/materialized repos underneath.

repos/*
!repos/
!repos/init.sh
!repos/repos.list


