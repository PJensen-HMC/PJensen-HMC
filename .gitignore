# ignore everything in ~/
*

# --- root files ---
!.bashrc
!.gitignore
!CLAUDE.md
!init.sh
!pr.sh
!repos.list

# --- .claude directory ---
!.claude/
.claude/*
!.claude/.gitignore
!.claude/.secrets.example
!.claude/settings.json
!.claude/settings.local.json
!.claude/statusline.sh
!.claude/send_statusline.sh
!.claude/send_test.sh

# --- README ---
!README.md

# --- docs ---
!indexing-topology.md

# --- r&d spikes ---
!r&d/
r&d/*
!r&d/*.md

# --- local plugins ---
!.claude/plugins/
.claude/plugins/*
!.claude/plugins/local/
.claude/plugins/local/*
!.claude/plugins/local/hmc-tools/
.claude/plugins/local/hmc-tools/*
!.claude/plugins/local/hmc-tools/.claude-plugin/
.claude/plugins/local/hmc-tools/.claude-plugin/*
!.claude/plugins/local/hmc-tools/.claude-plugin/plugin.json
!.claude/plugins/local/hmc-tools/skills/
.claude/plugins/local/hmc-tools/skills/*
!.claude/plugins/local/hmc-tools/skills/upgrade-hmc-pkgs/
.claude/plugins/local/hmc-tools/skills/upgrade-hmc-pkgs/*
!.claude/plugins/local/hmc-tools/skills/upgrade-hmc-pkgs/SKILL.md
!.claude/plugins/local/hmc-tools/skills/hmc_dot_net_list_pkgs/
.claude/plugins/local/hmc-tools/skills/hmc_dot_net_list_pkgs/*
!.claude/plugins/local/hmc-tools/skills/hmc_dot_net_list_pkgs/SKILL.md
!.claude/plugins/local/hmc-tools/skills/safe-push/
.claude/plugins/local/hmc-tools/skills/safe-push/*
!.claude/plugins/local/hmc-tools/skills/safe-push/SKILL.md

# --- memory ---
!.claude/projects/
.claude/projects/*
!.claude/projects/-home-devadmin/
.claude/projects/-home-devadmin/*
!.claude/projects/-home-devadmin/memory/
.claude/projects/-home-devadmin/memory/*
!.claude/projects/-home-devadmin/memory/*.md
